; Engine configuration file.
; It's best edited using the editor and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]
config/name="Empires of History V2"
run/main_scene="res://scenes/MainMenu.tscn"

[autoload]
GameManager="*res://src/Core/GameManager.cs"
SceneRouter="*res://src/Core/SceneRouter.cs"
TurnSystem="*res://src/Core/TurnSystem.cs"

[dotnet]
project/assembly_name="EmpiresOfHistoryV2"
