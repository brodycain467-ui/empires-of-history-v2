theme_override_colors/font_color = Color(0.941, 0.902, 0.8, 1)
theme_override_font_sizes/font_size = 12
autowrap_mode = 3

; Empty state message — shown until a nation is selected
[node name="EmptyStateLabel" type="Label" parent="MainLayout/CenterArea/NationInfoPanel/PanelVBox"]
layout_mode = 2
size_flags_vertical = 3
horizontal_alignment = 1
vertical_alignment = 1
text = "Select a nation"
theme_override_colors/font_color = Color(0.627, 0.502, 0.376, 0.7)
theme_override_font_sizes/font_size = 14
autowrap_mode = 3

; ════════════════════════════════════════════════════════════════════════════
; BOTTOM TAB BAR  (full-width, 60 px, icon+label tab buttons)
; ════════════════════════════════════════════════════════════════════════════

[node name="BottomTabBar" type="Panel" parent="MainLayout"]
layout_mode = 2
custom_minimum_size = Vector2(0, 60)
theme_override_styles/panel = SubResource("StyleBoxFlat_panel")

[node name="TabButtons" type="HBoxContainer" parent="MainLayout/BottomTabBar"]
layout_mode = 1
anchor_left = 0.5
anchor_right = 0.5
anchor_top = 0.0
anchor_bottom = 1.0
grow_horizontal = 2
offset_left = -540.0
offset_right = 540.0
theme_override_constants/separation = 4

[node name="GovernmentTabBtn" type="Button" parent="MainLayout/BottomTabBar/TabButtons"]
layout_mode = 2
custom_minimum_size = Vector2(100, 0)
size_flags_horizontal = 3
text = "GOVERNMENT"
theme_override_font_sizes/font_size = 11

[node name="EconomyTabBtn" type="Button" parent="MainLayout/BottomTabBar/TabButtons"]
layout_mode = 2
custom_minimum_size = Vector2(90, 0)
size_flags_horizontal = 3
text = "ECONOMY"
theme_override_font_sizes/font_size = 11

[node name="MilitaryTabBtn" type="Button" parent="MainLayout/BottomTabBar/TabButtons"]
layout_mode = 2
custom_minimum_size = Vector2(90, 0)
size_flags_horizontal = 3
text = "MILITARY"
theme_override_font_sizes/font_size = 11

[node name="DiplomacyTabBtn" type="Button" parent="MainLayout/BottomTabBar/TabButtons"]
layout_mode = 2
custom_minimum_size = Vector2(100, 0)
size_flags_horizontal = 3
text = "DIPLOMACY"
theme_override_font_sizes/font_size = 11

[node name="TechnologyTabBtn" type="Button" parent="MainLayout/BottomTabBar/TabButtons"]
layout_mode = 2
custom_minimum_size = Vector2(100, 0)
size_flags_horizontal = 3
text = "TECHNOLOGY"
theme_override_font_sizes/font_size = 11

; Religion tab — PLACEHOLDER, grayed out, non-functional (per Phase 2 constraints)
[node name="ReligionTabBtn" type="Button" parent="MainLayout/BottomTabBar/TabButtons"]
layout_mode = 2
custom_minimum_size = Vector2(90, 0)
size_flags_horizontal = 3
text = "RELIGION"
disabled = true
theme_override_font_sizes/font_size = 11
tooltip_text = "Religion — not yet implemented"

[node name="IntelligenceTabBtn" type="Button" parent="MainLayout/BottomTabBar/TabButtons"]
layout_mode = 2
custom_minimum_size = Vector2(110, 0)
size_flags_horizontal = 3
text = "INTELLIGENCE"
theme_override_font_sizes/font_size = 11

[node name="GIATabBtn" type="Button" parent="MainLayout/BottomTabBar/TabButtons"]
layout_mode = 2
custom_minimum_size = Vector2(60, 0)
size_flags_horizontal = 3
text = "GIA"
theme_override_font_sizes/font_size = 11

[node name="MapModesTabBtn" type="Button" parent="MainLayout/BottomTabBar/TabButtons"]
layout_mode = 2
custom_minimum_size = Vector2(100, 0)
size_flags_horizontal = 3
text = "MAP MODES"
theme_override_font_sizes/font_size = 11
