[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://src/UI/TurnControls.cs" id="1_script"]

[node name="TurnControls" type="HBoxContainer"]
layout_mode = 2
theme_override_constants/separation = 8
script = ExtResource("1_script")

[node name="DateLabel" type="Label" parent="." unique_name_in_owner=true]
layout_mode = 2
text = "January 1, 2011 — Turn 1"

[node name="AdvanceTurnBtn" type="Button" parent="." unique_name_in_owner=true]
layout_mode = 2
text = "END TURN ▶"

[node name="SaveBtn" type="Button" parent="." unique_name_in_owner=true]
layout_mode = 2
text = "💾 SAVE"

[node name="ToastLabel" type="Label" parent="." unique_name_in_owner=true]
layout_mode = 2
visible = false
text = "Saved!"
theme_override_colors/font_color = Color(0.788235, 0.658824, 0.298039, 1)

[node name="ToastTimer" type="Timer" parent="." unique_name_in_owner=true]
one_shot = true
