{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "scenarios database schema",
  "type": "object",
  "required": [
    "database",
    "schema_version",
    "minimum_engine_version",
    "last_updated",
    "record_count",
    "records"
  ],
  "properties": {
    "database": {
      "type": "string",
      "const": "scenarios"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "minimum_engine_version": {
      "type": "string",
      "const": "0.4.95"
    },
    "last_updated": {
      "type": "string"
    },
    "record_count": {
      "type": "integer",
      "minimum": 0
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "owner_id",
          "controller_id",
          "core_owner_id",
          "population",
          "culture_id",
          "religion_id",
          "government_id",
          "historical_region",
          "neighbor_ids",
          "metadata",
          "sources",
          "confidence",
          "verified",
          "notes",
          "future_extensions"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^scenario_[a-z0-9_]+$"
          },
          "name": {
            "type": "string"
          },
          "owner_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "controller_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "core_owner_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "population": {
            "type": "integer",
            "minimum": 0
          },
          "culture_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "religion_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "government_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "historical_region": {
            "type": [
              "string",
              "null"
            ]
          },
          "neighbor_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "confidence": {
            "type": "string",
            "enum": [
              "Verified",
              "Probable",
              "Disputed",
              "Unverified"
            ]
          },
          "verified": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          },
          "future_extensions": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
